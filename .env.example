# market_brief/.env.example — market_brief_v1.0.0
# Copy to .env, fill in, then: set -a; source .env; set +a
# --- tier switch (free | mid | premium | platinum) ---
SCREENER_TIER=free
# --- required on every tier (all tiers use at least Haiku) ---
ANTHROPIC_API_KEY=
# --- news sources ---
FINNHUB_API_KEY=
ALPHAVANTAGE_API_KEY=
BENZINGA_API_KEY=          # premium/platinum only; leave blank otherwise
# --- delivery (dedicated screener bot; reuse existing chat id) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=6075312586
# --- platinum: political / Trump volatility alerts ---
# Free default archive (~5-min refresh). Override if it goes dark.
POLITICAL_ARCHIVE_URL=https://ix.cnn.io/data/truth-social/truth_archive.json
# Optional paid low-latency feed (WebSocket/HTTP bridge). Preferred when set.
POLITICAL_PUSH_ENDPOINT=
# --- optional ---
SCREENER_DRY_RUN=0         # 1 = print report instead of sending
